# ============================================
# MMAS Advogados — Environment Variables
# ============================================

# App (REQUIRED in production — set to your Vercel/custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                    # openssl rand -base64 32

# Supabase (Postgres)
DATABASE_URL=                        # postgresql://user:pass@host:5432/db
SUPABASE_URL=                        # https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # Service role key (server-side only)

# OpenRouter (LLM)
OPENROUTER_API_KEY=                  # OpenRouter API key

# Groq (Whisper STT)
GROQ_API_KEY=                        # Groq API key

# Resend (Email)
RESEND_API_KEY=                      # Resend API key
RESEND_FROM_EMAIL=                   # Verified domain sender (e.g., noreply@mmasadvogados.adv.br). Falls back to onboarding@resend.dev (sandbox)

# Telegram Bot
TELEGRAM_BOT_TOKEN=                  # BotFather token
TELEGRAM_WEBHOOK_SECRET=             # Random string for webhook validation

# Admin Seed
ADMIN_EMAIL=                         # Initial admin email
ADMIN_PASSWORD=                      # Initial admin password (will be hashed)
